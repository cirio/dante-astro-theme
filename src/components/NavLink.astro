---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL; // e.g. '/dante-astro-theme/'
const resolvedHref = href?.startsWith('/') ? `${base}${href.slice(1)}` : href;
const isActive = resolvedHref === pathname || resolvedHref === pathname.replace(/\/$/, '');
---

<a class:list={[className, { 'underline decoration-1 underline-offset-2': isActive }]} href={resolvedHref} {...props}>
    <slot />
</a>
